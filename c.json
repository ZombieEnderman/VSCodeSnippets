{
	"output and format": {
		"prefix": "pf",
		"body": "printf(\"$0\", ${1:a});",
		"description": "格式化輸出"
	},
	"input and format": {
		"prefix": "sf",
		"body": "scanf(\"%${0:d}\", &${1:a});",
		"description": "格式化輸入"
	},
	"output char": {
		"prefix": "pc",
		"body": "putchar(${0:a});",
		"description": "字元輸出"
	},
	"input of char buffered": {
		"prefix": "gcr",
		"body": "getchar();",
		"description": "緩衝字元輸入"
	},
	"output string skip line": {
		"prefix": "ps",
		"body": "puts(${0:a});",
		"description": "自動換行字串輸出"
	},
	"output string stream": {
		"prefix": "fp",
		"body": "fputs(${0:a}, stdout);",
		"description": "指定串流字串輸出"
	},
	"input string": {
		"prefix": "fg",
		"body": "fgets(${0:a}, ${1:2}, stdin);",
		"description": "指定串流字串輸入"
	},
	"input char no echo": {
		"prefix": "gc",
		"body": "getch();",
		"description": "無痕即時字元輸入"
	},
	"input char echo": {
		"prefix": "gce",
		"body": "getche();",
		"description": "即時字元輸入"
	},
	"convert type": {
		"prefix": "tp",
		"body": "(${0:int})${1:a}",
		"description": "強制型別轉換"
	},
	"sizeof operator": {
		"prefix": "sif",
		"body": "sizeof ${0:a}",
		"description": "獲取記憶體大小"
	},
	"if...else": {
		"prefix": "ie",
		"body": [
			"if (${1:true})",
			"{",
			"    $2",
			"}",
			"else",
			"{",
			"    $0",
			"}"
		],
		"description": "if...else結構"
	},
	"if...else if...else": {
		"prefix": "ef",
		"body": [
			"if (${1:false})",
			"{",
			"    $2",
			"}",
			"else if (${3:true})",
			"{",
			"    $4",
			"}",
			"else",
			"{",
			"    $0",
			"}"
		],
		"description": "if...else if...else結構"
	},
	"switch...case": {
		"prefix": "sh",
		"body": [
			"switch (${1:0})",
			"{",
			"    case ${2:1}:",
			"        $3",
			"        break;",
			"    default:",
			"        $0",
			"        break;",
			"}"
		],
		"description": "switch...case結構"
	},
	"for loop": {
		"prefix": "flp",
		"body": [
			"for (int ${1:i} = ${2:0}; ${1:i} < ${3:10}; ${1:i}++)",
			"{",
			"   $0",
			"}"
		],
		"description": "for迴圈"
	},
	"while": {
		"prefix": "we",
		"body": [
			"while (${1:true})",
			"{",
			"    $0",
			"}"
		],
		"description": "while迴圈"
	},
	"do...while": {
		"prefix": "dw",
		"body": [
			"do",
			"{",
			"    $1",
			"} while (${0:false});"
		],
		"description": "do...while迴圈"
	},
	"include header": {
		"prefix": "ic",
		"body": "#include ${0:<stdio.h>}",
		"description": "引用標頭檔"
	}
}