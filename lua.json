{
	"output and skip line": {
		"prefix": "pt",
		"body": "print($0)",
		"description": "終端機跳行輸出"
	},
	"output": {
		"prefix": "wr",
		"body": "io.write($0)",
		"description": "終端機輸出"
	},
	"input": {
		"prefix": "rd",
		"body": "io.read($0)",
		"description": "終端機輸入"
	},
	"format": {
		"prefix": "ft",
		"body": "string.format(\"$1\", ${0:a})",
		"description": "格式化"
	},
	"local variable": {
		"prefix": "lo",
		"body": "local ${1:a} = $0",
		"description": "區域變數"
	},
	"if...else": {
		"prefix": "ie",
		"body": [
			"if ${1:true} then",
			"    $2",
			"else",
			"    $0",
			"end"
		],
		"description": "if...else結構"
	},
	"if...elsif...else": {
		"prefix": "ef",
		"body": [
			"if ${1:false} then",
			"    $2",
			"elseif ${3:true} then",
			"    $4",
			"else",
			"    $0",
			"end"
		],
		"description": "if...elseif...else結構"
	},
	"for loop": {
		"prefix": "fd",
		"body": [
			"for ${1:i} = ${2:1}, ${3:10} do",
			"   $0",
			"end"
		],
		"description": "for迴圈"
	},
	"for...in": {
		"prefix": "fi",
		"body": [
			"for ${1:key}, ${2:value} in pairs(${3:{\\}}) do",
			"   $0",
			"end"
		],
		"description": "for...in迴圈"
	},
	"while": {
		"prefix": "we",
		"body": [
			"while ${1:a > 10} do",
			"    $0",
			"end"
		],
		"description": "while迴圈"
	},
	"repeat...until": {
		"prefix": "ru",
		"body": [
			"repeat",
			"   $0",
			"until ${1:a > 10}"
		],
		"description": "repeat...until迴圈"
	},
	"function": {
		"prefix": "fn",
		"body": [
			"local function ${1:list}($2)",
			"    $0",
			"end"
		],
		"description": "函數"
	}
}