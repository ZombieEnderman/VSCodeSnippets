{
	"output and skip line": {
		"prefix": "ps",
		"body": "puts ${0:Object}",
		"description": "終端機跳行輸出"
	},
	"output": {
		"prefix": "pt",
		"body": "print(${0:Object})",
		"description": "終端機輸出"
	},
	"output and format": {
		"prefix": "pf",
		"body": "printf(\"${0:%d}\",${1:0})",
		"description": "終端機格式化輸出"
	},
	"input": {
		"prefix": "gs",
		"body": "gets",
		"description": "終端機輸入"
	},
	"remove escape character": {
		"prefix": ".cp",
		"body": ".chomp",
		"description": "去除跳脫字元"
	},
	"get type": {
		"prefix": ".cs",
		"body": ".class",
		"description": "獲取類型"
	},
	"if...else": {
		"prefix": "ie",
		"body": [
			"if ${1:true}",
			"  ${2:nil}",
			"else",
			"  ${0:nil}",
			"end"
		],
		"description": "if...else結構"
	},
	"if...elsif...else": {
		"prefix": "ef",
		"body": [
			"if ${1:false}",
			"  ${2:nil}",
			"elsif ${3:true}",
			"  ${4:nil}",
			"else",
			"  ${0:nil}",
			"end"
		],
		"description": "if...elsif...else結構"
	},
	"unless": {
		"prefix": "us",
		"body": [
			"unless ${1:a > 10}",
			"  $0",
			"end",
		],
		"description": "unless結構"
	},
	"case...when": {
		"prefix": "cw",
		"body": [
			"case ${1:a}",
			"when ${2:0}",
			"  $3",
			"else",
			"  $0",
			"end"
		],
		"description": "case...when結構"
	},
	"for...in": {
		"prefix": "fr",
		"body": [
			"for ${1:i} in ${2:1..2}",
			"  $0",
			"end"
		],
		"description": "for...in迴圈"
	},
	"each not string": {
		"prefix": "eh",
		"body": [
			"${1:a}.each do |${2:i}|",
			"  $0",
			"end"
		],
		"description": "each迴圈(非字串)"
	},
	"each string": {
		"prefix": "ehc",
		"body": [
			"${1:a}.each_char do |${2:i}|",
			"  $0",
			"end"
		],
		"description": "each迴圈(字串)"
	},
	"while": {
		"prefix": "we",
		"body": [
			"while ${1:a < 1}",
			"  $0",
			"end"
		],
		"description": "while迴圈"
	},
	"until": {
		"prefix": "ul",
		"body": [
			"until ${1:a > 10}",
			"  $0",
			"end",
		],
		"description": "until迴圈"
	},
	"loop...do": {
		"prefix": "lp",
		"body": [
			"loop do",
			"  $0",
			"end"
		],
		"description": "無限迴圈"
	},
	"def": {
		"prefix": "df",
		"body": [
			"def ${1:name}(${2:params})",
			"  ${0:nil}",
			"end"
		],
		"description": "函數"
	}
}